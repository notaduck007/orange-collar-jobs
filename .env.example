# Lovable Cloud (Supabase) — public, build-time values consumed by Vite.
# Real values are injected automatically by Lovable Cloud; this file
# documents the variable names for local / external setups.

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Server-side equivalents (used by SSR / server functions)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
# SwaggerHub personal API key — used by scripts/publish-swagger.sh and CI
# Get yours at: https://app.swaggerhub.com/settings/apiKey
SWAGGER_API_KEY=