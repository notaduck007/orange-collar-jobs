# ═══════════════════════════════════════════════════════════════════════════════
# WarehouseJobs.com — Environment Variables (monorepo root)
# Copy to .env and fill in values. Never commit .env.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Frontend (Vite / TanStack Start) ───────────────────────────────────────────
# NestJS API base URL — used by the frontend API client and /dev/diagnostics page
VITE_API_BASE_URL=http://localhost:3001

# Public build-time values (also prefixed VITE_ for client bundle)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Server-side SSR equivalents
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"

# ── API — App ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Primary frontend URL (auth email links). Dev CORS also allows :5173 and :8080.
CORS_ORIGIN=http://localhost:8080
# Optional extra browser origins (comma-separated).
# CORS_ALLOWED_ORIGINS=https://staging.example.com

# ── API — Database (PostgreSQL 16) ─────────────────────────────────────────────
# Docker Compose maps Postgres to host port 5433 (avoids local 5432 conflicts)
DATABASE_URL=postgresql://wj_user:wj_dev_password@localhost:5433/warehousejobs
TEST_DATABASE_URL=postgresql://wj_user:wj_dev_password@localhost:5433/warehousejobs_test

# ── API — Redis ────────────────────────────────────────────────────────────────
# Docker Compose maps Redis to host port 6380
REDIS_URL=redis://localhost:6380

# ── API — JWT ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_a_secure_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_generate_a_different_secure_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── API — Object storage (MinIO local → Cloudflare R2 production) ─────────────
STORAGE_ENDPOINT=http://minio:9000
# Public URL used in stored file links (what the browser loads).
# Must be reachable from the user's browser. Defaults to STORAGE_ENDPOINT when not set.
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=wj_minio_user
STORAGE_SECRET_KEY=wj_minio_dev_password
STORAGE_BUCKET_RESUMES=resumes
STORAGE_BUCKET_LOGOS=company-logos
STORAGE_BUCKET_ADS=ad-assets
STORAGE_FORCE_PATH_STYLE=true

# ── API — Email ────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@warehousejobs.com
EMAIL_FROM_NAME=WarehouseJobs
# Set true to send via Resend in development (or use a real re_* key — auto-detected).
EMAIL_SEND_IN_DEV=false

# ── API — Twilio SMS ─────────────────────────────────────────────────────────────
# REST API uses Account SID + Auth Token (OAuth app creds are for console tooling).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Must be a Twilio-owned number (Console → Phone Numbers), not your personal cell.
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_APP_CLIENT_ID=
TWILIO_APP_CLIENT_SECRET=

# Notification smoke test (bun run notifications:test)
NOTIFICATION_TEST_EMAIL=
NOTIFICATION_TEST_PHONE=

# ── API — Batch ingestion ──────────────────────────────────────────────────────
# Store bcrypt hash only — never the plaintext API key
API_KEY_HASH=local_dev_placeholder_batch_api_key_hash

# ── API — Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Tooling — SwaggerHub (scripts/publish-swagger.sh, CI) ──────────────────────
# https://app.swaggerhub.com/settings/apiKey
SWAGGER_API_KEY=
POSTMAN_API_KEY=
