            "body": { "mode": "raw", "raw": "{\n  \"featured\": true\n}" },
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('200 updated', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "5. DELETE /api/v1/jobs/:id (soft close)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('204 closed', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Jobs (Phase 3)",
      "description": "Job search and listing — Phase 3. Batch ingest remains Phase 4.",
      "item": [
        {
          "name": "GET /api/v1/jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 paginated listing', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has data array', () => pm.expect(body.data).to.be.an('array'));",
                  "pm.test('has meta', () => pm.expect(body.meta).to.have.property('page'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            },
            "description": "Phase 3. Paginated job listing."
          },
          "response": []
        },
        {
          "name": "POST /api/v1/jobs/batch — Batch ingest",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('404 until Phase 4 batch', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Api-Key", "value": "{{swaggerApiKey}}" }
            ],
            "auth": { "type": "noauth" },
