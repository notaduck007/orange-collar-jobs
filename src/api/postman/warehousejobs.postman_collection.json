{
  "info": {
    "_postman_id": "wj-collection-v1",
    "name": "WarehouseJobs API v1",
    "description": "Complete Postman collection for the WarehouseJobs.com REST API.\n\n## Quick Start\n1. Import this collection AND the `warehousejobs.postman_environment.json` environment.\n2. Select the **WarehouseJobs — Local Dev** environment.\n3. Start the stack: `docker compose up -d && bun run --cwd src/api start:dev`\n4. Run the **System / Health Check** request — expect `200 OK { status: 'ok' }`.\n5. Once the Auth domain is implemented, run **Auth / Login** — the test script auto-saves the JWT to `bearerToken`.\n\n## Authorization\nAll protected endpoints use the `bearerToken` environment variable via the collection-level Bearer auth.\nBatch ingestion endpoints additionally require the `X-Api-Key` header (see `swaggerApiKey`).\n\n## OpenAPI Contract\nThe authoritative spec is at `docs/api/openapi.yaml`.\nSwagger UI: http://localhost:3001/api/docs (dev only).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [],
  "item": [
    {
      "name": "System",
      "description": "Infrastructure endpoints — no auth required.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "GET /api/health — version-neutral liveness check.\n\nExpected: 200 `{ status: 'ok', info: { db, redis, storage } }`\n503 if any dependency is down."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status is ok', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.equal('ok');",
                  "});",
                  "pm.test('db, redis, storage reported', () => {",
                  "  const info = pm.response.json().info ?? {};",
                  "  pm.expect(info).to.have.property('db');",
                  "  pm.expect(info).to.have.property('redis');",
                  "  pm.expect(info).to.have.property('storage');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "200 All healthy",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"info\": {\n    \"db\": { \"status\": \"up\" },\n    \"redis\": { \"status\": \"up\" },\n    \"storage\": { \"status\": \"up\" }\n  },\n  \"error\": {},\n  \"details\": {\n    \"db\": { \"status\": \"up\" },\n    \"redis\": { \"status\": \"up\" },\n    \"storage\": { \"status\": \"up\" }\n  }\n}"
            },
            {
              "name": "503 Storage down",
              "status": "Service Unavailable",
              "code": 503,
              "body": "{\n  \"status\": \"error\",\n  \"info\": {\n    \"db\": { \"status\": \"up\" },\n    \"redis\": { \"status\": \"up\" }\n  },\n  \"error\": {\n    \"storage\": {\n      \"status\": \"down\",\n      \"message\": \"Storage service unreachable\"\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/docs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "docs"]
            },
            "description": "OpenAPI Swagger UI — only available when NODE_ENV != production."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth — Core",
      "description": "JWT identity endpoints backed by core/auth. Business-logic auth (register/login/refresh) will be added in Phase 2 under Auth — Domain.",
      "item": [
        {
          "name": "GET /api/v1/me — Get current user",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "me"]
            },
            "description": "Returns the caller's identity from Bearer JWT.\n\nExpected 200: `{ id, email, role }` where role is `admin`, `vendor`, or `seeker`.\n\nExpected 401 if no/invalid/unverified token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.test('returns id, email, role', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('email');",
                  "    pm.expect(body).to.have.property('role');",
                  "  });",
                  "} else {",
                  "  pm.test('401 when no/bad token', () => pm.response.to.have.status(401));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "200 Authenticated",
              "status": "OK",
              "code": 200,
              "body": "{ \"id\": \"3f2504e0-4f89-11d3-9a0c-0305e82c3301\", \"email\": \"worker@example.com\", \"role\": \"seeker\" }"
            },
            {
              "name": "401 No token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"statusCode\": 401, \"message\": \"Unauthorized\", \"error\": \"Unauthorized\" }"
            },
            {
              "name": "401 Expired token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"statusCode\": 401, \"message\": \"Unauthorized\", \"error\": \"Unauthorized\" }"
            }
          ]
        }
      ]
    },
    {
      "name": "Phase 2 — Walkthrough (run in order)",
      "description": "Guided auth flow for manual testing. Run requests 1→9 in order. Step 3 requires pasting `verificationToken` from API logs or Postgres (see docs/demo/phase2-demo.md).",
      "item": [
        {
          "name": "1. Health (Phase 1 compat)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 ok', () => pm.response.to.have.status(200));",
                  "pm.test('status ok', () => pm.expect(pm.response.json().status).to.equal('ok'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Register (unique email)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('testEmail', `postman-${Date.now()}@warehousejobs.test`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.userId) pm.environment.set('registeredUserId', body.userId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"seeker\",\n  \"fullName\": \"Postman User\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "3. Verify email",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-email",
            "description": "Set `verificationToken` from API [DEV EMAIL] log or Postgres before running."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 verified', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "4. Login",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 login', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.accessToken) pm.environment.set('bearerToken', body.accessToken);",
                  "if (body.refreshToken) pm.environment.set('refreshToken', body.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "5. GET /me (Phase 1 compat)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 me', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.expect(body).to.have.property('id');",
                  "pm.expect(body).to.have.property('email');",
                  "pm.expect(body).to.have.property('role');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "6. Refresh tokens",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 refresh', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.accessToken) pm.environment.set('bearerToken', body.accessToken);",
                  "if (body.refreshToken) pm.environment.set('refreshToken', body.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "7. Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('204 logout', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "8. Forgot password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"{{testEmail}}\" }"
            },
            "url": "{{baseUrl}}/api/v1/auth/forgot-password"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('200 forgot', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "9. Reset password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"NewSecure2!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/reset-password",
            "description": "Set `resetToken` from [DEV EMAIL] log or Postgres after step 8."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('200 reset', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Domain (Phase 2)",
      "description": "Authentication domain — register, login, logout, refresh, verify-email, forgot/reset password. All implemented in Phase 2.",
      "item": [
        {
          "name": "POST /api/v1/auth/register",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"seeker\",\n  \"fullName\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Creates a new user and sends verification email.\n\nExpected 201: `{ message, userId }`"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/auth/login",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Phase 2. Authenticates a user and returns a JWT pair.\n\nThe test script auto-saves the accessToken to `bearerToken`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.accessToken) {",
                  "    pm.environment.set('bearerToken', body.accessToken);",
                  "    console.log('bearerToken saved to environment');",
                  "  }",
                  "  if (body.refreshToken) {",
                  "    pm.environment.set('refreshToken', body.refreshToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /api/v1/auth/refresh",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Phase 2. Exchange a refresh token for a new access + refresh token pair."
          },
          "response": []
        },
        {
          "name": "POST /api/v1/auth/logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Phase 2. Revokes the refresh token (invalidates the session)."
          },
          "response": []
        },
        {
          "name": "POST /api/v1/auth/forgot-password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"{{testEmail}}\" }"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            },
            "description": "Phase 2. Sends a password-reset email (always 200)."
          },
          "response": []
        },
        {
          "name": "POST /api/v1/auth/verify-email",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-email"]
            },
            "description": "Confirms email using opaque token from register email or DB."
          },
          "response": []
        },
        {
          "name": "POST /api/v1/auth/reset-password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"NewSecure2!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            },
            "description": "Sets new password; revokes all refresh tokens for user."
          },
          "response": []
        }
      ]
    },
    },
    {
      "name": "Phase 3 — Walkthrough (run in order)",
      "description": "Jobs CRUD after Phase 2 auth (bearerToken required for mutating steps). Set companyId before admin POST. See docs/demo/phase3-demo.md.",
      "item": [
        {
          "name": "1. GET /api/v1/jobs (search)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/jobs?page=1&pageSize=20" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 listing', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has data', () => pm.expect(body.data).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. POST /api/v1/jobs (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Reach Truck Operator — 2nd Shift\",\n  \"category\": \"Forklift Operator\",\n  \"location\": \"Dallas, TX\",\n  \"city\": \"Dallas\",\n  \"state\": \"TX\",\n  \"zip\": \"75201\",\n  \"employmentType\": \"full_time\",\n  \"shift\": \"second\",\n  \"payMin\": 18,\n  \"payMax\": 22,\n  \"payPeriod\": \"hour\",\n  \"description\": \"Operate reach trucks in a fast-paced warehouse environment.\",\n  \"requirements\": \"1+ years experience\",\n  \"companyId\": \"{{companyId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/jobs",
            "description": "Requires bearerToken (admin) and companyId in environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.id) pm.environment.set('jobId', body.id);",
                  "if (body.slug) pm.environment.set('jobSlug', body.slug);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. GET /api/v1/jobs/:slug",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/jobs/{{jobSlug}}" },
          "event": [
            {
              "listen": "test",
