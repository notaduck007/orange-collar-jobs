{
  "id": "wj-local-env",
  "name": "WarehouseJobs — Local Dev",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "default",
      "enabled": true,
      "description": "API base URL. Change to https://api.warehousejobs.com for production."
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "JWT access token — set by Login or Refresh test scripts."
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Refresh token — set by Login test script."
    },
    {
      "key": "verificationToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Email verification token from [DEV EMAIL] log or Postgres after Register."
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Password reset token from [DEV EMAIL] log or Postgres after Forgot password."
    },
    {
      "key": "swaggerApiKey",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "X-Api-Key header for batch ingestion endpoints."
    },
    {
      "key": "testEmail",
      "value": "test@warehousejobs.com",
      "type": "default",
      "enabled": true,
      "description": "Register/login email. Walkthrough step 2 sets a unique email automatically."
    },
    {
      "key": "testPassword",
      "value": "Test1234!",
      "type": "secret",
      "enabled": true,
      "description": "Password (min 8 characters)."
    },
    {
      "key": "registeredUserId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Set by Register walkthrough step."
    },
    {
      "key": "companyId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Company UUID for admin POST /jobs — from Postgres companies table."
    },
    {
      "key": "companyPackageId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Vendor package UUID for POST /jobs."
    },
    {
      "key": "jobId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Set by Phase 3 walkthrough after job create."
    },
    {
      "key": "jobSlug",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Set by Phase 3 walkthrough after job create."
    }
  ],
  "_postman_variable_scope": "environment",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
}
