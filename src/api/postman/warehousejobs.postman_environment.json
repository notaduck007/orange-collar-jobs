{
  "id": "wj-local-env",
  "name": "WarehouseJobs — Local Dev",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "default",
      "enabled": true,
      "description": "API base URL. Change to https://api.warehousejobs.com for production."
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Paste a JWT from POST /api/v1/auth/login (or use the Login request — it auto-sets this variable via the test script)."
    },
    {
      "key": "swaggerApiKey",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "X-Api-Key header for batch ingestion endpoints. Set to the value of SWAGGER_API_KEY in your .env."
    },
    {
      "key": "testEmail",
      "value": "test@warehousejobs.com",
      "type": "default",
      "enabled": true
    },
    {
      "key": "testPassword",
      "value": "Test1234!",
      "type": "secret",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
}
