# CI-only Postman environment — same variables as local dev; baseUrl overridden at runtime.
{
  "id": "wj-ci-env",
  "name": "WarehouseJobs — CI",
  "values": [
    { "key": "baseUrl", "value": "http://localhost:3001", "type": "default", "enabled": true },
    { "key": "bearerToken", "value": "", "type": "secret", "enabled": true },
    { "key": "refreshToken", "value": "", "type": "secret", "enabled": true },
    { "key": "verificationToken", "value": "", "type": "secret", "enabled": true },
    { "key": "resetToken", "value": "", "type": "secret", "enabled": true },
    { "key": "testEmail", "value": "postman-ci@warehousejobs.test", "type": "default", "enabled": true },
    { "key": "testPassword", "value": "Test1234!", "type": "secret", "enabled": true },
    { "key": "swaggerApiKey", "value": "", "type": "secret", "enabled": true }
  ],
  "_postman_variable_scope": "environment",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
}
