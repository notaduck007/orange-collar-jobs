# ═══════════════════════════════════════════════════════════════════════════════
# WarehouseJobs API — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
# Docker Compose default:
DATABASE_URL=postgresql://wj_user:wj_dev_password@localhost:5433/warehousejobs
# Test DB (used by integration + E2E tests):
TEST_DATABASE_URL=postgresql://wj_user:wj_dev_password@localhost:5433/warehousejobs_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_a_secure_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_generate_a_different_secure_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Object Storage (MinIO locally, Cloudflare R2 in production) ──────────────
# Docker Compose MinIO defaults:
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=wj_minio_user
STORAGE_SECRET_KEY=wj_minio_dev_password
STORAGE_BUCKET_RESUMES=resumes
STORAGE_BUCKET_LOGOS=company-logos
STORAGE_BUCKET_ADS=ad-assets
STORAGE_FORCE_PATH_STYLE=true   # Required for MinIO; set false for R2

# ── Email (Resend recommended; SendGrid also supported) ───────────────────────
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@warehousejobs.com
EMAIL_FROM_NAME=WarehouseJobs

# ── Twilio SMS ─────────────────────────────────────────────────────────────────
# Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Console → Phone Numbers → Manage (10DLC number)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Console → Verify → Services (create a service, copy the SID)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Batch Ingestion ───────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
# Hash with bcrypt before storing: bcrypt.hash(key, 12)
# Store the plaintext key securely (e.g. Vault) — never commit it
API_KEY_HASH=bcrypt_hash_of_batch_api_key_goes_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── SwaggerHub (CI publish only — do not commit actual key) ──────────────────
# SWAGGER_API_KEY=
