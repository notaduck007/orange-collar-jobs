// ═══════════════════════════════════════════════════════════════════════════
// WarehouseJobs Prisma Schema
// Source of truth for the PostgreSQL database structure.
// Run `bun run db:migrate:dev` to apply changes.
// Connection URL: prisma.config.ts (Prisma 7)
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  vendor
  seeker
}

enum JobStatus {
  draft
  active
  published
  closed
  expired
}

enum JobSourceType {
  direct      // posted via platform UI by a vendor
  scraped     // ingested by automated scraper
  api         // posted via vendor API key
  syndicated  // imported from partner feed
}

enum EmploymentType {
  full_time
  part_time
  temp
  temp_to_hire
  contract
  seasonal
}

enum JobShift {
  first
  second
  third
  weekend
  flexible
}

enum PayPeriod {
  hour
  day
  week
  month
  year
}

enum TemperatureEnv {
  ambient
  cooler
  freezer
}

enum ApplicationStatus {
  new
  reviewing
  shortlisted
  interview
  offer
  hired
  rejected
  withdrawn
}

enum ScreeningQuestionType {
  yes_no
  single
  multi
  number
  text
}

enum BatchStatus {
  queued
  processing
  completed
  failed
}

enum AdStatus {
  active
  paused
  ended
}

enum NotificationType {
  system
  application
  message
  marketing
  auth
}

enum NotificationKind {
  auth
  transactional
  marketing
}

enum NotificationChannel {
  email
  sms
  in_app
}

enum DeliveryStatus {
  pending
  queued
  sent
  delivered
  failed
  bounced
  skipped
}

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  cancelled
  failed
}

enum CampaignChannel {
  email
  sms
}

enum OtpPurpose {
  verify_contact
  login_2fa
  enable_2fa
}

enum OtpChannel {
  email
  sms
}

enum MfaMethod {
  sms
  email
  totp
}

enum ConsentSource {
  register
  settings
  campaign
}

// ── Users ────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  role              UserRole  @default(seeker)
  fullName          String?   @map("full_name")
  phone             String?
  emailVerifiedAt   DateTime? @map("email_verified_at")
  migrationSource   String?   @map("migration_source")  // "supabase" for migrated users
  requiresReset     Boolean   @default(false) @map("requires_reset")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  refreshTokens            RefreshToken[]
  emailVerifications       EmailVerification[]
  passwordResets           PasswordReset[]
  applications             Application[]
  company                  Company?               @relation("CompanyOwner")
  notifications            Notification[]
  notificationPreference   NotificationPreference?
  marketingConsents        MarketingConsent[]
  userMfa                  UserMfa?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ── Companies ────────────────────────────────────────────────────────────────

enum CompanyVerificationStatus {
  unverified
  pending
  verified
  rejected

  @@map("company_verification_status")
}

enum CompanyStatus {
  active
  suspended

  @@map("company_status")
}

model Company {
  id                      String                    @id @default(uuid())
  ownerId                 String?                   @unique @map("owner_id")
  name                    String
  slug                    String                    @unique
  description             String?
  website                 String?
  logoUrl                 String?                   @map("logo_url")
  industry                String?
  hqCity                  String?                   @map("hq_city")
  hqState                 String?                   @map("hq_state")
  location                String?
  status                  String                    @default("active")
  verified                Boolean                   @default(false)
  verificationStatus      String                    @default("unverified") @map("verification_status")
  verifiedAt              DateTime?                 @map("verified_at")
  verifiedBy              String?                   @map("verified_by")
  verificationNote        String?                   @map("verification_note")
  verificationEvidenceUrl String?                   @map("verification_evidence_url")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime?                 @updatedAt @map("updated_at")

  owner    User?            @relation("CompanyOwner", fields: [ownerId], references: [id])
  jobs     Job[]
  packages CompanyPackage[]

  @@map("companies")
}

model CompanyPackage {
  id            String    @id @default(uuid())
  companyId     String    @map("company_id")
  name          String
  totalCredits  Int       @map("total_credits")
  usedCredits   Int       @default(0) @map("used_credits")
  expiresAt     DateTime? @map("expires_at")
  purchasedAt   DateTime  @default(now()) @map("purchased_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs    Job[]

  @@index([companyId])
  @@map("company_packages")
}

// ── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id                    String         @id @default(uuid())
  companyId             String?        @map("company_id")
  companyPackageId      String?        @map("company_package_id")
  title                 String
  slug                  String         @unique
  category              String
  categorySlug          String         @map("category_slug")
  location              String
  city                  String
  state                 String
  zip                   String?
  lat                   Float?
  lng                   Float?
  employmentType        EmploymentType @map("employment_type")
  shift                 JobShift
  payMin                Float?         @map("pay_min")
  payMax                Float?         @map("pay_max")
  payPeriod             PayPeriod?     @map("pay_period")
  description           String
  requirements          String?
  temperatureEnv        TemperatureEnv? @map("temperature_env")
  certificationsRequired String[]      @map("certifications_required") @default([])
  liftRequirementLbs    Int?           @map("lift_requirement_lbs")
  overtimeAvailable     Boolean        @default(false) @map("overtime_available")
  weeklyPay             Boolean        @default(false) @map("weekly_pay")
  quickHire             Boolean        @default(false) @map("quick_hire")
  status                JobStatus      @default(draft)
  sourceType            JobSourceType  @default(direct) @map("source_type")
  externalId            String?        @map("external_id")
  sourceUrl             String?        @map("source_url")
  featured              Boolean        @default(false)
  featuredUntil         DateTime?      @map("featured_until")
  views                 Int            @default(0)
  postedAt              DateTime?      @map("posted_at")
  expiresAt             DateTime?      @map("expires_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  company        Company?         @relation(fields: [companyId], references: [id])
  package        CompanyPackage?  @relation(fields: [companyPackageId], references: [id])
  screeningQuestions ScreeningQuestion[]
  interviewSlots     InterviewSlot[]
  applications       Application[]

  @@unique([companyId, externalId])
  @@index([status, postedAt])
  @@index([sourceType, status])
  @@index([city, state, status])
  @@map("jobs")
}

model ScreeningQuestion {
  id        String                @id @default(uuid())
  jobId     String                @map("job_id")
  prompt    String
  type      ScreeningQuestionType
  options   String[]              @default([])
  required  Boolean               @default(false)
  sortOrder Int                   @map("sort_order")

  job     Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  answers ApplicationAnswer[]

  @@index([jobId])
  @@map("screening_questions")
}

model InterviewSlot {
  id           String   @id @default(uuid())
  jobId        String   @map("job_id")
  startsAt     DateTime @map("starts_at")
  endsAt       DateTime @map("ends_at")
  maxBookings  Int      @default(1) @map("max_bookings")
  bookedCount  Int      @default(0) @map("booked_count")

  job      Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  bookings InterviewBooking[]

  @@index([jobId])
  @@map("interview_slots")
}

// ── Applications ─────────────────────────────────────────────────────────────

model Application {
  id          String            @id @default(uuid())
  jobId       String            @map("job_id")
  seekerId    String?           @map("seeker_id")
  // Guest fields for unauthenticated apply
  guestName   String?           @map("guest_name")
  guestPhone  String?           @map("guest_phone")
  guestZip    String?           @map("guest_zip")
  guestEmail  String?           @map("guest_email")
  resumeUrl   String?           @map("resume_url")
  coverNote   String?           @map("cover_note")
  status      ApplicationStatus @default(new)
  appliedAt   DateTime          @default(now()) @map("applied_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  job      Job                @relation(fields: [jobId], references: [id])
  seeker   User?              @relation(fields: [seekerId], references: [id])
  answers  ApplicationAnswer[]
  booking  InterviewBooking?

  @@unique([jobId, seekerId])
  @@index([jobId])
  @@index([seekerId])
  @@map("applications")
}

model ApplicationAnswer {
  id          String @id @default(uuid())
  applicationId String @map("application_id")
  questionId  String @map("question_id")
  answer      String

  application Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question    ScreeningQuestion @relation(fields: [questionId], references: [id])

  @@map("application_answers")
}

model InterviewBooking {
  id            String   @id @default(uuid())
  applicationId String   @unique @map("application_id")
  slotId        String   @map("slot_id")
  createdAt     DateTime @default(now()) @map("created_at")

  application Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  slot        InterviewSlot @relation(fields: [slotId], references: [id])

  @@map("interview_bookings")
}

// ── Batch Ingestion ───────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(uuid())
  keyHash     String    @unique @map("key_hash")
  description String
  companyId   String?   @map("company_id")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

model BatchJob {
  id          String      @id @default(uuid())
  companyId   String?     @map("company_id")
  status      BatchStatus @default(queued)
  total       Int         @default(0)
  created     Int         @default(0)
  updated     Int         @default(0)
  skipped     Int         @default(0)
  failed      Int         @default(0)
  errors      Json        @default("[]")
  startedAt   DateTime?   @map("started_at")
  completedAt DateTime?   @map("completed_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([status])
  @@map("batch_jobs")
}

// ── Advertising ───────────────────────────────────────────────────────────────

model AdCampaign {
  id          String   @id @default(uuid())
  name        String
  imageUrl    String   @map("image_url")
  linkUrl     String   @map("link_url")
  slot        String
  status      AdStatus @default(active)
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  targeting   Json     @default("{}")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status, startsAt, endsAt])
  @@map("ad_campaigns")
}

// ── Notifications (Phase 4.5) ───────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  title     String
  body      String
  link      String?
  type      NotificationType @default(system)
  senderId  String?          @map("sender_id")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  emailTransactional Boolean  @default(true) @map("email_transactional")
  emailMarketing     Boolean  @default(false) @map("email_marketing")
  smsTransactional   Boolean  @default(true) @map("sms_transactional")
  smsMarketing       Boolean  @default(false) @map("sms_marketing")
  inApp              Boolean  @default(true) @map("in_app")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationDelivery {
  id             String              @id @default(uuid())
  userId         String?             @map("user_id")
  channel        NotificationChannel
  kind           NotificationKind
  template       String
  status         DeliveryStatus      @default(pending)
  providerId     String?             @map("provider_id")
  error          String?
  idempotencyKey String?             @unique @map("idempotency_key")
  campaignId     String?             @map("campaign_id")
  toAddress      String?             @map("to_address")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  campaign NotificationCampaign? @relation(fields: [campaignId], references: [id])

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@map("notification_deliveries")
}

model MarketingConsent {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  channel   CampaignChannel
  source    ConsentSource
  optedInAt DateTime        @default(now()) @map("opted_in_at")
  revokedAt DateTime?       @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
  @@map("marketing_consents")
}

model SmsOptOut {
  id         String   @id @default(uuid())
  phone      String   @unique
  optedOutAt DateTime @default(now()) @map("opted_out_at")
  source     String   @default("STOP")

  @@map("sms_opt_outs")
}

model NotificationCampaign {
  id          String          @id @default(uuid())
  name        String
  channel     CampaignChannel
  status      CampaignStatus  @default(draft)
  segment     Json            @default("{}")
  subject     String?
  htmlBody    String?         @map("html_body")
  textBody    String?         @map("text_body")
  scheduledAt DateTime?       @map("scheduled_at")
  sentAt      DateTime?       @map("sent_at")
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  deliveries NotificationDelivery[]

  @@index([status])
  @@map("notification_campaigns")
}

model OtpChallenge {
  id          String     @id @default(uuid())
  userId      String?    @map("user_id")
  channel     OtpChannel
  destination String
  purpose     OtpPurpose
  codeHash    String?    @map("code_hash")
  providerSid String?    @map("provider_sid")
  attempts    Int        @default(0)
  maxAttempts Int        @default(5) @map("max_attempts")
  expiresAt   DateTime   @map("expires_at")
  verifiedAt  DateTime?  @map("verified_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([destination, purpose])
  @@index([userId])
  @@map("otp_challenges")
}

model UserMfa {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  method      MfaMethod
  destination String?
  enabledAt   DateTime  @default(now()) @map("enabled_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_mfa")
}
